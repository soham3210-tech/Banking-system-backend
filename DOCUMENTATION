// src/controllers/auth.controller.js
const user = await userModel.findOne({ email }).select("+password")
// ⚠️ .select("+password") needed because password has select: false
✅ User retrieved, including hashed password






Step 2: Compare plain text password with hash
JavaScript
// Schema has this method:
userSchema.methods.comparePassword = async function (password) {
  return await bcrypt.compare(password, this.password);
  // bcrypt.compare("myPassword123", "$2a$10$abc123...")
  // Returns: true or false
}

const isValidPassword = await user.comparePassword(password);

if (!isValidPassword) {
  return res.status(401).json({
    message: "Email or password is INVALID"
  });
}
✅ Password verified using bcrypt




Step 3: Generate JWT token
JavaScript
const token = jwt.sign(
  { userid: user._id },  // Payload
  process.env.JWT_SECRET, // Secret key
  { expiresIn: "3d" }    // Token valid for 3 days
);
✅ JWT created with user ID payload




Step 4: Set cookie & send response
JavaScript
res.cookie("token", token);  // Set HTTP-only cookie

res.status(200).json({
  user: {
    _id: user._id,
    email: user.email,
    name: user.name
  },
  token
});
✅ Token in both cookie and response body





